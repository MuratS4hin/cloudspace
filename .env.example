# ── Storage paths ────────────────────────────────────────────────────────────
# Set these to an absolute path on your Pi (SD card, SSD, USB drive, NVMe …)
# Defaults (relative ./data/*) are used when these are blank or not set.
STORAGE_PATH=/media/pifive/A2BE1391BE135D5B/DATA/AppData/cloudspace
POSTGRES_DATA_PATH=/media/pifive/A2BE1391BE135D5B/DATA/AppData/db

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=cloudspace
POSTGRES_USER=cloudspace
POSTGRES_PASSWORD=cloudspace
POSTGRES_PORT=5432

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=8086

APP_NAME=CloudSpace
API_PREFIX=/api
SECRET_KEY=cloudspace-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256
CORS_ORIGINS=*
